# Banco de dados SQLite (caminho relativo à pasta prisma/)
DATABASE_URL="file:./dev.db"

# Token da API do Football-Data.org (https://www.football-data.org/client/register)
FOOTBALL_DATA_TOKEN="seu-token-aqui"

# Segredo para assinar os cookies de sessão (gere com: openssl rand -hex 32)
SESSION_SECRET="troque-por-um-segredo-aleatorio"

# Código de convite inicial para registro (pode ser alterado no painel admin)
INVITE_CODE="COPA2026"
